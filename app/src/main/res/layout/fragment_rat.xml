<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hacker_space">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛠️ RAT CONTROLS"
            android:textSize="20sp"
            android:textColor="#00FF41"
            android:fontFamily="sans-serif-bold"
            android:shadowColor="#00FF41"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="10"
            android:layout_marginBottom="16dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="7">

            <Button
                android:id="@+id/btnCamFront"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:text="📸 Kamera Depan"
                android:background="#1A1A1A"
                android:textColor="#00FF41"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnCamBack"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:text="📸 Kamera Belakang"
                android:background="#1A1A1A"
                android:textColor="#00FF41"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnGmail"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:text="📧 Buka Gmail"
                android:background="#1A1A1A"
                android:textColor="#00FF41"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:text="🖼️ Buka Galeri"
                android:background="#1A1A1A"
                android:textColor="#00FF41"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnSMS"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:text="✉️ Buka SMS"
                android:background="#1A1A1A"
                android:textColor="#00FF41"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnWhatsApp"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:text="💬 Buka WhatsApp"
                android:background="#1A1A1A"
                android:textColor="#00FF41"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnFlash"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:text="🔦 Senter"
                android:background="#1A1A1A"
                android:textColor="#00FF41"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnLocation"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:text="📍 Lokasi"
                android:background="#1A1A1A"
                android:textColor="#00FF41"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnLock"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:text="🔒 Lock Screen"
                android:background="#1A1A1A"
                android:textColor="#00FF41"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnSendSMS"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:text="📤 Kirim SMS"
                android:background="#1A1A1A"
                android:textColor="#00FF41"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnLiveCam"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="2"
                android:text="🎥 LIVE CAMERA"
                android:background="#00FF41"
                android:textColor="#000000"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnScreenMonitor"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="2"
                android:text="🖥️ SCREEN MONITOR"
                android:background="#00FF41"
                android:textColor="#000000"
                android:layout_margin="4dp" />

        </GridLayout>
    </LinearLayout>
</ScrollView>
